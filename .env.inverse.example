# ═══════════════════════════════════════════════════════════
#  INVERSE BOT — Ters Strateji Konfigürasyonu
#  Long sinyal geldiğinde SHORT açar, Short sinyal geldiğinde LONG açar
# ═══════════════════════════════════════════════════════════

# ── Strategy Mode (BU SATIR KRİTİK) ──────────────────────
STRATEGY_MODE=inverse

# ── Ayrı Veritabanı (mevcut botla çakışmaz) ──────────────
DB_PATH=trades_inverse.db

# ── Dashboard (mevcut bot 8081'de, inverse 8080'de) ──────
DASHBOARD_PORT=8080

# ── Telegram (ayrı bot/chat kullanılabilir) ───────────────
TELEGRAM_BOT_TOKEN=your_inverse_bot_token_here
TELEGRAM_CHAT_ID=your_inverse_chat_id_here

# ── Bybit API (AYRI API KEY KULLANIN!) ───────────────────
BYBIT_API_KEY=your_inverse_api_key_here
BYBIT_API_SECRET=your_inverse_api_secret_here
BYBIT_TESTNET=false

# ── Trading Config ────────────────────────────────────────
TRADING_ENABLED=true
LEVERAGE=10
MARGIN_PER_TRADE=100
MAX_DCA_COUNT=3
DCA_THRESHOLD_PCT=20.0
ORDER_TIMEOUT_SEC=300

# ── TP Configuration ─────────────────────────────────────
TP1_PCT=1.0
TP2_PCT=2.5
TP3_PCT=5.0

# ── Screener ──────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300
MIN_VOLUME_24H_USD=10000000

# ── Funding Rate Filter ──────────────────────────────────
SHORT_FUNDING_RATE_LIMIT=-0.008

# ── Blacklist & Overrides (isteğe bağlı) ─────────────────
# COIN_BLACKLIST=BTCUSDT,ETHUSDT
# COIN_MARGIN_OVERRIDES=BTCUSDT:500,ETHUSDT:300
# COIN_DCA_OVERRIDES=BTCUSDT:3,SOLUSDT:5
