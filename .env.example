# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Scanner Configuration
SCAN_INTERVAL_SECONDS=300
MIN_VOLUME_24H_USD=10000000
DASHBOARD_PORT=8081

# ── Live Trading Configuration ──────────────────────
# Set TRADING_ENABLED=true to enable live trading on Bybit
TRADING_ENABLED=false
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=false

# Position sizing
LEVERAGE=10
MARGIN_PER_TRADE=100

# DCA (Dollar Cost Averaging) — no stop loss
MAX_DCA_COUNT=3
DCA_THRESHOLD_PCT=20.0

# Cancel unfilled limit orders after N seconds
ORDER_TIMEOUT_SEC=300

# ── Take-Profit Percentages ──────────────────────────
# Configurable TP levels from average entry price
TP1_PCT=1.0
TP2_PCT=2.5
TP3_PCT=5.0
ATR_TP2_MULT=3.5
ATR_TP3_MULT=6.0

# ── Coin Blacklist ────────────────────────────────────
# Comma-separated list of symbols to skip entirely (no scan, no trade)
# Example: COIN_BLACKLIST=BTCUSDT,ETHUSDT
COIN_BLACKLIST=

# ── Per-Coin Margin Overrides ─────────────────────────
# Override the default MARGIN_PER_TRADE for specific coins
# Format: SYMBOL:margin,SYMBOL:margin  (margin in USD)
# Example: COIN_MARGIN_OVERRIDES=BTCUSDT:500,ETHUSDT:300
COIN_MARGIN_OVERRIDES=

# ── Per-Coin DCA Override ──────────────────────────────────
# Override the default DCA_THRESHOLD_PCT for specific coins
# Format: SYMBOL:pct,SYMBOL:pct  (pct = DCA trigger %)
# Example: COIN_DCA_OVERRIDES=BTCUSDT:3,ETHUSDT:3,SOLUSDT:5,AVAXUSDT:5,LINKUSDT:7
COIN_DCA_OVERRIDES=
